# arc-eval-service -- local configuration template.
#
# Copy this file to `.env` and edit the values for your environment:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must never be committed (it can hold secrets). It is
# loaded automatically by `docker compose up` and by the runtime Make targets
# (`make run`, `make migrate`, `make migration`, `make downgrade`). Every service
# setting is an `ARC_EVAL_*` variable; provider API keys are plain names that the
# model profiles reference by env-var name (never inlined into a profile).

# ---- Database --------------------------------------------------------------
# Async Postgres URL (psycopg3 driver). This default targets the Postgres that
# `docker compose up db` publishes on localhost, which is what `make run` uses.
# The full `docker compose up` stack overrides this to the internal `db` host.
ARC_EVAL_DATABASE_URL=postgresql+psycopg://arc:arc@localhost:5432/arc_eval

# ---- Judge models (bring your own key) -------------------------------------
# JSON array of server-side judge-model profiles. Each profile names a provider,
# a model id, and the NAME of the env var that holds its API key (`api_key_env`);
# the secret itself is resolved at call time and never stored in the profile.
# Single-quote the whole value so the inner JSON survives shell and compose
# parsing. Leave empty (`ARC_EVAL_MODEL_PROFILES=[]`) to run without scoring:
# every metric records a "no judge configured" error and is omitted from the
# response.
ARC_EVAL_MODEL_PROFILES='[{"name":"default","provider":"openai_compatible","model":"gpt-4o-mini","api_key_env":"OPENAI_API_KEY"}]'

# Profile used when a judge does not name one. Must match a `name` above.
ARC_EVAL_DEFAULT_MODEL=default

# The secret referenced by `api_key_env` above. Replace with a real key. For a
# self-hosted OpenAI-compatible server (vLLM, Ollama, ...) any non-empty value
# works. NEVER commit a real key.
OPENAI_API_KEY=sk-replace-me

# ---- Judging / catalog -----------------------------------------------------
# Judge used when a request does not name one. Must exist in the catalog.
ARC_EVAL_DEFAULT_JUDGE=default

# Optional path to a catalog directory (with `metric/` and `judge/`
# subdirectories) that overrides the bundled catalog. Leave unset to use the
# built-in catalog.
# ARC_EVAL_PROMPTS_PATH=/absolute/path/to/catalog

# ---- App / logging ---------------------------------------------------------
# Title shown in the API docs.
ARC_EVAL_APP_NAME=arc-eval-service
# Service name returned by GET /health.
ARC_EVAL_SERVICE_NAME=arc-eval-service
# Log level for the JSON logger (DEBUG, INFO, WARNING, ERROR).
ARC_EVAL_LOG_LEVEL=INFO
